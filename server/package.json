{
  "name": "streamkit-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "StreamKit signaling server — WebSocket-based session management, WebRTC offer/answer/ICE relay, controller/spectator roles, and PTZ command broadcast.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.6.3",
    "tsx": "^4.19.2"
  }
}
